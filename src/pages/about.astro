---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import abhilashImg from '~/assets/images/abhilash_john.jpg';
import arunImg from '~/assets/images/arun_tk.jpg';
const metadata = {
  title: 'About Us',
  description:
    'Learn about Lookuptax: a team of finance experts, technologists, and problem solvers making global Tax ID validation efficient, affordable, and secure. Meet the founders solving the Identity Gap in cross-border commerce.',
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Lookuptax',
  url: 'https://www.lookuptax.com',
  description: 'High-precision, API-first global tax identity validation systems.',
  founders: [
    {
      '@type': 'Person',
      name: 'Abhilash John Philip',
      jobTitle: 'Co-Founder',
      worksFor: {
        '@type': 'Organization',
        name: 'Lookuptax',
      },
      url: 'https://www.linkedin.com/in/abhilashjohnphilip/',
    },
    {
      '@type': 'Person',
      name: 'Arun Kumar TK',
      jobTitle: 'Co-Founder',
      worksFor: {
        '@type': 'Organization',
        name: 'Lookuptax',
      },
      url: 'https://www.linkedin.com/in/tkarun/',
    },
  ],
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="About"
    image={{
      src: '~/assets/images/use_case.png',
      alt: 'Colorful Image',
      style:
        'width: 100%; height: auto; max-width: 100%; max-height: 214px; object-fit: contain; background-color: transparent !important; box-shadow: none;',
    }}
  >
    <Fragment slot="title">
      You are in expert hands <br />
      <span class="text-accent dark:text-white highlight"> Global Tax ID Validation Infrastructure</span>
    </Fragment>

    <Fragment slot="subtitle"
      >Lookuptax provides API-first tax ID validation for global businesses, helping companies verify tax identities,
      reduce compliance risk, and prevent fraud. Built by experts in taxation and billing systems, Lookuptax is designed
      to deliver accurate, real-time validation across multiple jurisdictions.
    </Fragment>
  </Hero>

